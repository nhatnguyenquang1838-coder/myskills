{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pfc/agent-action-event.schema.json",
  "title": "PFC Agent Action Event",
  "description": "Schema for one line in .pm/audit/runs/{run_id}.agent-action.ndjson. Validate NDJSON files line by line.",
  "type": "object",
  "required": [
    "run_id",
    "action_id",
    "agent",
    "action_type",
    "status",
    "summary",
    "bcbs239_principle_tag"
  ],
  "properties": {
    "log_level": {"enum": ["semantic_action"]},
    "ts": {"type": "string"},
    "pid": {"type": ["integer", "number", "null"]},
    "run_id": {"type": "string"},
    "action_id": {"type": "string"},
    "parent_event_id": {"type": ["string", "null"]},
    "agent": {"type": "string"},
    "agent_role": {"type": ["string", "null"]},
    "action_type": {
      "enum": [
        "USER_REQUEST_RECEIVED",
        "USE_CASE_RESOLVED",
        "READINESS_CHECKED",
        "GRAPH_LOADED",
        "RUN_CONTEXT_BUILT",
        "MEMORY_CONTEXT_LOADED",
        "CONTRACT_CHECKED",
        "SKILL_CALLED",
        "SKILL_OUTPUT_VALIDATED",
        "GRAPH_DELTA_PROPOSED",
        "CASCADE_CHECKED",
        "FINANCE_BASIS_CHECKED",
        "REPORT_CLAIM_CHECKED",
        "CIRCUIT_BREAKER_EVALUATED",
        "OUTPUT_GENERATED",
        "WRITEBACK_REQUESTED",
        "WRITEBACK_DONE",
        "WRITEBACK_BLOCKED",
        "CHECKPOINT_WRITTEN",
        "ERROR_HANDLED"
      ]
    },
    "use_case": {"type": ["string", "null"]},
    "mode": {"enum": ["M0", "M1", "M2", "M3", "UNKNOWN", null]},
    "run_type": {"type": ["string", "null"]},
    "status": {"enum": ["STARTED", "PASS", "DOWNGRADED", "BLOCKED", "FAILED", "SKIPPED"]},
    "bcbs239_principle_tag": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "01-governance-and-infrastructure",
          "02-risk-data-aggregation",
          "03-risk-reporting-practices",
          "04-supervisory-review-remediation",
          "05-2023-progress-lessons",
          "06-pfc-skill-guardrail-map",
          "07-bcbs239-skill-contract-guidance"
        ]
      },
      "description": "Required BCBS239 lineage/control tags. Values map to files in knowledge/references/bcbs239/."
    },
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "output_refs": {"type": "array", "items": {"type": "string"}},
    "graph_nodes_read": {"type": "array", "items": {"type": "string"}},
    "graph_deltas_proposed": {"type": "array", "items": {"type": "string"}},
    "graph_nodes_written": {"type": "array", "items": {"type": "string"}},
    "enforcement_gates": {"type": "array", "items": {"type": "string"}},
    "guardrails_applied": {"type": "array", "items": {"type": "string"}},
    "breaker_state": {"enum": ["CLOSED", "HALF_OPEN", "OPEN", "NOT_EVALUATED", null]},
    "blocked_claims": {"type": "array", "items": {"type": "string"}},
    "writeback_decision": {"enum": ["none", "draft_only", "approved_writeback", "blocked", "not_applicable", null]},
    "duration_ms": {"type": ["number", "null"]},
    "skill_id": {"type": ["string", "null"]},
    "contract_id": {"type": ["string", "null"]},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "memory_ids": {"type": "array", "items": {"type": "string"}},
    "history_ids": {"type": "array", "items": {"type": "string"}},
    "file_paths_touched": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "string"}},
    "errors": {"type": "array", "items": {"type": "string"}},
    "recovery_action": {"type": ["string", "null"]},
    "review_required": {"type": ["boolean", "null"]},
    "redaction_note": {"type": ["string", "null"]},
    "summary": {"type": "string"}
  },
  "additionalProperties": true
}
