{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pfc/kiro-hook.schema.json",
  "title": "Kiro v1 Hook File with PFC Execution Tier",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "hooks"],
  "properties": {
    "version": {"const": "v1"},
    "hooks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/hook"}
    }
  },
  "$defs": {
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "trigger", "execution_tier", "action"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "execution_tier": {
          "type": "string",
          "enum": ["blocking", "async"],
          "description": "PFC execution tier. blocking hooks run on the critical path; async hooks are scheduled in background and must not block the next semantic turn."
        },
        "trigger": {
          "type": "string",
          "enum": [
            "SessionStart",
            "Stop",
            "PreToolUse",
            "PostToolUse",
            "PreTaskExec",
            "PostTaskExec",
            "UserPromptSubmit",
            "PostFileCreate",
            "PostFileSave",
            "PostFileDelete"
          ]
        },
        "matcher": {"type": "string"},
        "action": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "command"],
              "properties": {
                "type": {"const": "command"},
                "command": {"type": "string", "minLength": 1}
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "prompt"],
              "properties": {
                "type": {"const": "agent"},
                "prompt": {"type": "string", "minLength": 1}
              }
            }
          ]
        },
        "timeout": {"type": "integer", "minimum": 0},
        "enabled": {"type": "boolean"}
      }
    }
  }
}
