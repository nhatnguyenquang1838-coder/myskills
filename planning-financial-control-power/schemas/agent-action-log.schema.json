{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pfc/agent-action-log.schema.json",
  "title": "PFC Agent Action Log",
  "type": "object",
  "required": ["log_version", "project_id", "run_id", "actions"],
  "properties": {
    "log_version": {"type": "string"},
    "project_id": {"type": "string"},
    "run_id": {"type": "string"},
    "run_date": {"type": ["string", "null"]},
    "actions": {
      "type": "array",
      "items": {"$ref": "#/$defs/action"}
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": [
        "action_id",
        "timestamp",
        "agent",
        "agent_role",
        "action_type",
        "use_case",
        "mode",
        "run_type",
        "status",
        "summary"
      ],
      "properties": {
        "action_id": {"type": "string"},
        "timestamp": {"type": "string"},
        "agent": {"type": "string"},
        "agent_role": {"type": "string"},
        "action_type": {
          "enum": [
            "USER_REQUEST_RECEIVED",
            "USE_CASE_RESOLVED",
            "READINESS_CHECKED",
            "GRAPH_LOADED",
            "RUN_CONTEXT_BUILT",
            "MEMORY_CONTEXT_LOADED",
            "CONTRACT_CHECKED",
            "SKILL_CALLED",
            "SKILL_OUTPUT_VALIDATED",
            "GRAPH_DELTA_PROPOSED",
            "CASCADE_CHECKED",
            "FINANCE_BASIS_CHECKED",
            "REPORT_CLAIM_CHECKED",
            "CIRCUIT_BREAKER_EVALUATED",
            "OUTPUT_GENERATED",
            "WRITEBACK_REQUESTED",
            "WRITEBACK_DONE",
            "WRITEBACK_BLOCKED",
            "CHECKPOINT_WRITTEN",
            "ERROR_HANDLED"
          ]
        },
        "use_case": {"type": "string"},
        "mode": {"enum": ["M0", "M1", "M2", "M3", "UNKNOWN"]},
        "run_type": {"type": "string"},
        "status": {"enum": ["STARTED", "PASS", "DOWNGRADED", "BLOCKED", "FAILED", "SKIPPED"]},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "output_refs": {"type": "array", "items": {"type": "string"}},
        "graph_nodes_read": {"type": "array", "items": {"type": "string"}},
        "graph_deltas_proposed": {"type": "array", "items": {"type": "string"}},
        "graph_nodes_written": {"type": "array", "items": {"type": "string"}},
        "enforcement_gates": {"type": "array", "items": {"type": "string"}},
        "guardrails_applied": {"type": "array", "items": {"type": "string"}},
        "breaker_state": {"enum": ["CLOSED", "HALF_OPEN", "OPEN", "NOT_EVALUATED"]},
        "blocked_claims": {"type": "array", "items": {"type": "string"}},
        "writeback_decision": {"enum": ["none", "draft_only", "approved_writeback", "blocked", "not_applicable"]},
        "duration_ms": {"type": ["number", "null"]},
        "skill_id": {"type": ["string", "null"]},
        "contract_id": {"type": ["string", "null"]},
        "source_ids": {"type": "array", "items": {"type": "string"}},
        "memory_ids": {"type": "array", "items": {"type": "string"}},
        "history_ids": {"type": "array", "items": {"type": "string"}},
        "file_paths_touched": {"type": "array", "items": {"type": "string"}},
        "commands_run": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"type": "string"}},
        "recovery_action": {"type": ["string", "null"]},
        "review_required": {"type": "boolean"},
        "redaction_note": {"type": ["string", "null"]},
        "summary": {"type": "string"}
      }
    }
  }
}
